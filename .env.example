# Copy to .env and fill in your key(s).

# ── Provider switch (v0.4) ─────────────────────────────────────────
# Which LLM powers story/text generation. Flip to "anthropic" to roll back to
# Claude instantly — both adapters stay live.
LLM_PROVIDER=gemini            # gemini | anthropic

PORT=3000
DATA_DIR=./data
CHAPTER_TARGET_BEATS=12
# A chapter is force-closed at this multiple of the target (F3 hard cap, ~18 beats)
# so it can never run forever. Or set CHAPTER_HARD_CAP_EXTRA=6 for target+6 instead.
CHAPTER_HARD_CAP_FACTOR=1.5

# ── Gemini (one key serves BOTH text and images) ───────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CLASSIFY_MODEL=gemini-2.5-flash-lite
# ⚠️ Must be an IMAGE model — NOT gemini-2.5-flash (that returns text).
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_SAFETY=relaxed          # default | relaxed  (relaxed = BLOCK_ONLY_HIGH; game boundaries stay the primary gate)
GEMINI_THINKING=on             # on | off  (on improves GM coherence; classifier always runs off)
# F5: give the GM a generous output floor so the late deltas fields (scene.present,
# chapterShouldEnd, suggestedActions) never truncate; bound thinking so it can't
# starve the JSON answer.
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_THINKING_BUDGET=1024

# ── Anthropic (kept as a live fallback) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MODEL=claude-sonnet-4-6
CLASSIFY_MODEL=claude-haiku-4-5-20251001

# ── Images ─────────────────────────────────────────────────────────
# gemini uses GEMINI_API_KEY + GEMINI_IMAGE_MODEL above. "pollinations" is
# keyless; "none" shows an SVG placeholder.
IMAGE_PROVIDER=gemini          # gemini | none | pollinations | cloudflare | huggingface
IMAGE_TIMEOUT_MS=30000         # abort a slow image render (falls back to placeholder)

# Other image providers (only if you switch IMAGE_PROVIDER to one of these):
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# HUGGINGFACE_TOKEN=

# In-chapter scene/action images (v0.2 §9). auto = on when a provider is set.
SCENE_IMAGES=auto              # off | auto
SCENE_IMAGE_BUDGET=3           # max non-action scene images per chapter (action is prioritized)

# Background image render queue (v0.3 §4). Renders never block a request; the UI
# shows a "generating" state and polls until ready. 429s honor Retry-After.
IMAGE_CONCURRENCY=2            # max simultaneous image renders
IMAGE_MAX_RETRIES=4            # retries per image on 429/5xx/timeout (fatal 4xx fail fast)
IMAGE_RETRY_TOTAL_MS=300000    # total retry budget per image (5 min)

# LLM resilience / auto-retry (v0.2 §11, provider-neutral in v0.4).
# LLM_* keys take precedence; the old CLAUDE_* names still work as fallbacks.
LLM_MAX_RETRIES=5
LLM_MAX_BACKOFF_MS=60000
LLM_CREDIT_RETRY_MS=30000
LLM_CREDIT_RETRY_TOTAL_MS=600000
